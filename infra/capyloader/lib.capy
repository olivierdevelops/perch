# --- Embedded bundle (set by `perch --build --include <path>`) -----------

function bundle_extract
    arg literal "bundle_extract"
    arg capture dst string
    write `{"event":"op","kind":"bundle_extract","args":{"dst":${dst}}}
`
end

# ────────────────────────────────────────────────────────────────────────────
# Conditionals — unified `if EXPR ... end`.
#
# Surface forms (all are normal block ops; bodies run only when the
# expression holds):
#
#   if NAME == LITERAL                  comparison
#   if NAME != LITERAL
#   if NAME >  NUMBER
#   if NAME <  NUMBER
#   if NAME >= NUMBER
#   if NAME <= NUMBER
#   if NAME                             truthy   (empty string/false/0/null/nil ⇒ false)
#   if not NAME                         falsy
#   if FUNC ARG                         predicate call (e.g. `if exists "./bin"`)
#
# `os` and `arch` are auto-bound at command start, so:
#
#   if os == "linux"
#   if arch == "arm64"
#
# All emit the unified `if` op kind (or `if_call` for the predicate form);
# the runtime evaluates and dispatches.
# ────────────────────────────────────────────────────────────────────────────

function cond_eq
    priority 200
    arg literal "if"
    arg capture lhs ident
    arg literal "=="
    arg capture rhs any
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if","args":{"op":"eq","lhs":${toJSON lhs},"rhs":${rhs}}}
${body}{"event":"op","kind":"_leave"}
`
end

function cond_neq
    priority 200
    arg literal "if"
    arg capture lhs ident
    arg literal "!="
    arg capture rhs any
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if","args":{"op":"neq","lhs":${toJSON lhs},"rhs":${rhs}}}
${body}{"event":"op","kind":"_leave"}
`
end

# `for_each VALUE NAME ... end` — iterate over a newline-separated
# string, binding each non-empty line to NAME for the body. Pairs with
# the `rest` arg modifier and with ops that return newline-joined lists
# (glob, list_dir, interfaces, dns_lookup).
function for_each
    priority 50
    arg literal "for_each"
    arg capture source any
    arg capture loopvar ident
    block_closer end
    write `{"event":"op","kind":"_enter","name":"for_each","args":{"_0":${source},"_1":${toJSON loopvar}}}
${body}{"event":"op","kind":"_leave"}
`
end

function cond_gt
    priority 200
    arg literal "if"
    arg capture lhs ident
    arg literal ">"
    arg capture rhs any
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if","args":{"op":"gt","lhs":${toJSON lhs},"rhs":${rhs}}}
${body}{"event":"op","kind":"_leave"}
`
end

function cond_lt
    priority 200
    arg literal "if"
    arg capture lhs ident
    arg literal "<"
    arg capture rhs any
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if","args":{"op":"lt","lhs":${toJSON lhs},"rhs":${rhs}}}
${body}{"event":"op","kind":"_leave"}
`
end

function cond_ge
    priority 200
    arg literal "if"
    arg capture lhs ident
    arg literal ">="
    arg capture rhs any
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if","args":{"op":"ge","lhs":${toJSON lhs},"rhs":${rhs}}}
${body}{"event":"op","kind":"_leave"}
`
end

function cond_le
    priority 200
    arg literal "if"
    arg capture lhs ident
    arg literal "<="
    arg capture rhs any
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if","args":{"op":"le","lhs":${toJSON lhs},"rhs":${rhs}}}
${body}{"event":"op","kind":"_leave"}
`
end

# `if not NAME` outranks `if FUNC ARG` so that `not` doesn't get treated
# as a predicate function. Both are arity-3.
function cond_falsy
    priority 300
    arg literal "if"
    arg literal "not"
    arg capture lhs ident
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if","args":{"op":"falsy","lhs":${toJSON lhs}}}
${body}{"event":"op","kind":"_leave"}
`
end

function cond_call
    priority 150
    arg literal "if"
    arg capture func ident
    arg capture a0 string
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if_call","args":{"func":${toJSON func},"_0":${a0}}}
${body}{"event":"op","kind":"_leave"}
`
end

function cond_truthy
    arg literal "if"
    arg capture lhs ident
    block_closer end
    write `{"event":"op","kind":"_enter","name":"if","args":{"op":"truthy","lhs":${toJSON lhs}}}
${body}{"event":"op","kind":"_leave"}
`
end

# ────────────────────────────────────────────────────────────────────────────
# Execution contexts — block ops that wrap a body and change *how* it runs.
#
#   parallel ... end                          # children run concurrently
#   timeout "30s" ... end                     # wall-clock cap on the body
#   retry attempts:3 backoff:"exponential" ... end
#   with_env "GOOS=linux,CGO_ENABLED=0" ... end
#   with_cwd "./subproject" ... end
#   sandbox no_shell no_network ... end       # narrow capability mask
#
# Each is a block-op marker pair (_enter / _leave). The Go handler reads
# args and recurses into the body.
# ────────────────────────────────────────────────────────────────────────────

function parallel
    arg literal "parallel"
    block_closer end
    write `{"event":"op","kind":"_enter","name":"parallel","args":{}}
${body}{"event":"op","kind":"_leave"}
`
end

function timeout
    arg literal "timeout"
    arg capture duration string
    block_closer end
    write `{"event":"op","kind":"_enter","name":"timeout","args":{"duration":${duration}}}
${body}{"event":"op","kind":"_leave"}
`
end

# retry takes optional `attempts:N backoff:"S" base:"D" max_delay:"D"`
# modifiers on the opening line. Each modifier is a single token; the
# arg block below captures them as a single trailing string and the
# Go-side opRetry parser pulls them apart. For now we keep the form
# simple: one optional `attempts:N` is the most common case.
function retry
    priority 50
    arg literal "retry"
    arg capture attempts int
    block_closer end
    write `{"event":"op","kind":"_enter","name":"retry","args":{"attempts":${attempts}}}
${body}{"event":"op","kind":"_leave"}
`
end

function with_env
    arg literal "with_env"
    arg capture env string
    block_closer end
    write `{"event":"op","kind":"_enter","name":"with_env","args":{"env":${env}}}
${body}{"event":"op","kind":"_leave"}
`
end

function with_cwd
    arg literal "with_cwd"
    arg capture path string
    block_closer end
    write `{"event":"op","kind":"_enter","name":"with_cwd","args":{"path":${path}}}
${body}{"event":"op","kind":"_leave"}
`
end

# `sandbox FLAGS ... end` — narrow the in-language capability mask for
# the body. Flags is a single comma-joined string (no_shell,no_network,
# no_write,no_subprocess). The opening line accepts a single string
# argument for the flag list; future revisions may add named modifiers
# for allow_bin / allow_host / env / read_only / max_runtime.
function sandbox
    arg literal "sandbox"
    arg capture flags string
    block_closer end
    write `{"event":"op","kind":"_enter","name":"sandbox","args":{"flags":${flags}}}
${body}{"event":"op","kind":"_leave"}
`
end

# ────────────────────────────────────────────────────────────────────────────
# WASM execution — the constrained execution lane.
#
#   wasm_run "module.wasm"
#       wasm_arg         "--target=linux"
#       wasm_arg         "value1"
#       wasm_mount_read  "./src"
#       wasm_mount_write "./bin"
#       wasm_env         "GOOS,GOARCH"
#   end
#
# wasm_run loads a WebAssembly module via wazero and runs its `_start`
# function under WASI Preview 1. The body's marker ops (wasm_arg /
# wasm_mount_* / wasm_env) configure WASI capabilities — they're not
# executed; the wasm_run handler walks the body to collect config.
# Anything not declared is denied at module instantiation.
# ────────────────────────────────────────────────────────────────────────────

# wasm_run has two forms — disambiguated by argument shape:
#
#   wasm_run "./mod.wasm"   ← string literal → load from disk
#   wasm_run policy_wasm    ← bare ident     → resolve via bundle alias
#
# Same body shape (wasm_arg / wasm_mount_* / wasm_env), same capability
# gates. The ident form requires a matching `include "…" as policy_wasm`
# in the file-level `bundle ... end` section.
function wasm_run_alias
    priority 50
    arg literal "wasm_run"
    arg capture path ident
    block_closer end
    write `{"event":"op","kind":"_enter","name":"wasm_run","args":{"path":${toJSON path},"_alias":true}}
${body}{"event":"op","kind":"_leave"}
`
end

function wasm_run
    arg literal "wasm_run"
    arg capture path string
    block_closer end
    write `{"event":"op","kind":"_enter","name":"wasm_run","args":{"path":${path}}}
${body}{"event":"op","kind":"_leave"}
`
end

function wasm_arg
    arg literal "wasm_arg"
    arg capture v string
    write `{"event":"op","kind":"wasm_arg","args":{"value":${v}}}
`
end

function wasm_mount_read
    arg literal "wasm_mount_read"
    arg capture v string
    write `{"event":"op","kind":"wasm_mount_read","args":{"path":${v}}}
`
end

function wasm_mount_write
    arg literal "wasm_mount_write"
    arg capture v string
    write `{"event":"op","kind":"wasm_mount_write","args":{"path":${v}}}
`
end

function wasm_env
    arg literal "wasm_env"
    arg capture v string
    write `{"event":"op","kind":"wasm_env","args":{"names":${v}}}
`
end

# wasm_allow_host — per-module HTTP host allowlist. Composes AND-wise
# with the outer --allow-host policy. Required for any URL the module
# wants to fetch via the perch.http_get host import; modules with no
# wasm_allow_host see http_get → -1 for every URL.
function wasm_allow_host
    arg literal "wasm_allow_host"
    arg capture v string
    write `{"event":"op","kind":"wasm_allow_host","args":{"host":${v}}}
`
end

# ────────────────────────────────────────────────────────────────────────────
# Error handling — try / catch / finally / throw + match / case / else
#
# Section dividers `catch` / `finally` / `case` / `else` are emitted as
# sentinel ops inside the parent block's body. The interpreter's try /
# match handlers walk the body splitting on these sentinels.
# ────────────────────────────────────────────────────────────────────────────

# ────────────────────────────────────────────────────────────────────────────
# os "PLATFORM" ... end — execution context block.
#
# Body runs only when ${os} matches the declared target. Targets:
#   "darwin" | "linux" | "windows"     — exact ${os} match
#   "freebsd" | "openbsd" | "netbsd"   — exact ${os} match
#   "unix"                              — umbrella for darwin + linux + BSDs
#
# Design note: a future revision will fold this into a unified
# `with ... then ... end` block that carries any combination of
# context attributes (os, cwd, env, no_tty, allow_host, max_runtime,
# …). That refactor is blocked on a capy grammar capability that
# isn't in the current engine (multi-section blocks with attribute
# lines + body separator). For now `os "X" ... end` ships the
# OS-context piece; future commits add sibling blocks for the rest.
# ────────────────────────────────────────────────────────────────────────────

function os_block
    arg literal "os"
    arg capture target string
    when_followed_by indent
    block_closer end
    write `{"event":"op","kind":"_enter","name":"os","args":{"target":${target}}}
${body}{"event":"op","kind":"_leave"}
`
end

# arch "ARCH" ... end — architecture execution context block.
#
# Body runs only when ${arch} matches the declared target. Targets are
# Go GOARCH values: "amd64", "arm64", "386", "arm", "riscv64", etc.
# No umbrellas (every modern target is one of amd64 or arm64; mixing
# them is the case worth being explicit about).
#
# Pairs cleanly with os "PLATFORM" blocks for matrix-shaped builds:
#
#   os "linux"
#       arch "amd64"
#           shell "go build -o app-linux-x64 ./cmd/app"
#       end
#       arch "arm64"
#           shell "go build -o app-linux-arm64 ./cmd/app"
#       end
#   end
#
# When the unified `with ... do ... end ... end` block lands, `arch`
# becomes an attribute inside it ("with arch \"arm64\" do …"); this
# standalone block remains as the dedicated arch-only shape.

function arch_block
    arg literal "arch"
    arg capture target string
    when_followed_by indent
    block_closer end
    write `{"event":"op","kind":"_enter","name":"arch","args":{"target":${target}}}
${body}{"event":"op","kind":"_leave"}
`
end

# `try ... rescue ... finally ... end` — structured error handling.
#
# Uses capy `block_sections` (capy >= 5102dec): `rescue` and `finally` are
# interior section keywords, `end` the closer. Each section's sub-body
# renders into a same-named local (`${body}` / `${rescue}` / `${finally}`),
# empty when that section is omitted. We reconstruct the flat `_enter /
# _catch / _finally / _leave` marker stream the loader + opTry handler
# already consume, so the interpreter is unchanged. The error binding is
# always `err` (the universal convention; `${err.kind}` etc. inside rescue).
#
# Naming note: perch uses Ruby-style `try / rescue / finally` (not `catch`)
# because `catch` is the file-scope catch-all-command keyword. Distinct.
#
# opTry treats an EMPTY rescue body as "no catch arm" (the error propagates
# after finally), so `try … end` and `try … finally … end` correctly
# re-raise — only a non-empty `rescue` swallows.
function try
    arg literal "try"
    block_sections rescue finally closer end
    write `{"event":"op","kind":"_enter","name":"try","args":{}}
${body}{"event":"op","kind":"_catch","args":{"bind":"err"}}
${rescue}{"event":"op","kind":"_finally"}
${finally}{"event":"op","kind":"_leave"}
`
end

# `throw "MSG"` — re-raise inside a catch arm. Semantically the same as
# `fail "MSG"` (both produce ErrUserFail), but spelled `throw` to read
# clearly as "I caught this and decided to re-raise."
function throw_op
    arg literal "throw"
    arg capture msg string
    write `{"event":"op","kind":"fail","args":{"msg":${msg}}}
`
end

# `match "VALUE" ... case "X" ... case "Y" ... else ... end` —
# value-driven dispatch. First matching case wins; `else` is the
# fallback. The target is a string (typically an interpolated
# reference like `"${err.kind}"` or `"${os}"`); case values are
# string literals OR bare identifiers (so `case user_fail` works
# without quotes, matching the error-kind enum spelling).
function match_block
    arg literal "match"
    arg capture target string
    block_closer end
    write `{"event":"op","kind":"_enter","name":"match","args":{"target":${target}}}
${body}{"event":"op","kind":"_leave"}
`
end

# Ident form — `match os` / `match status` / `match err.kind` (no quotes,
# no `${...}`). Uses capy `dotted_ident` (>= 5102dec), which captures both a
# plain binding (`os`) and a dotted member path (`err.kind`) as one token.
# The runtime resolves args._target_var via b.Lookup — and error bindings
# are stored under their literal dotted key (`err.kind`), so `match err.kind`
# resolves directly. (Previously dotted names required `match "${err.kind}"`.)
function match_block_ident
    priority 40
    arg literal "match"
    arg capture name dotted_ident
    block_closer end
    write `{"event":"op","kind":"_enter","name":"match","args":{"_target_var":${toJSON name}}}
${body}{"event":"op","kind":"_leave"}
`
end


# Two case overloads: `case "literal"` and `case bare_ident` (for enum
# kinds). The ident form has higher priority so `case user_fail`
# without quotes is captured as the string "user_fail" automatically.
function case_arm_ident
    priority 50
    arg literal "case"
    arg capture value ident
    write `{"event":"op","kind":"_case","args":{"value":${toJSON value}}}
`
end

function case_arm
    arg literal "case"
    arg capture value string
    write `{"event":"op","kind":"_case","args":{"value":${value}}}
`
end

function else_arm
    arg literal "else"
    write `{"event":"op","kind":"_else","args":{}}
`
end

# `cache "KEY" "TTL" ... end` — user-keyed body cache. On miss: run the
# body and persist every `let X = ...` binding produced. On hit within
# TTL: skip the body and replay the captured bindings into scope.
# Honest framing: the user chooses what goes into the key — perch does
# NOT hash the body's transitive inputs (see ideas/05 for why).
function cache
    arg literal "cache"
    arg capture key string
    arg capture ttl string
    block_closer end
    write `{"event":"op","kind":"_enter","name":"cache","args":{"key":${key},"ttl":${ttl}}}
${body}{"event":"op","kind":"_leave"}
`
end

# ────────────────────────────────────────────────────────────────────────────
# `let NAME = OP_KIND ARG [ARG]` — capture an op's output into a variable.
# ────────────────────────────────────────────────────────────────────────────

function let_0args
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg capture op_kind ident
    write `{"event":"op","kind":${toJSON op_kind},"args":{},"capture_into":${toJSON name}}
`
end

function let_1arg
    priority 50
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg capture op_kind ident
    arg capture a0 any
    write `{"event":"op","kind":${toJSON op_kind},"args":{"_0":${a0}},"capture_into":${toJSON name}}
`
end

# Ident form — `let body = http_get url` (bare ident arg, no quotes,
# no ${...}). Emits `_0_var` instead of `_0`; the universal resolver
# in InterpolateArgs turns that into `_0 = b.Lookup(<name>)` before
# the handler runs. Higher priority than let_1arg so capy picks this
# when a0 is a bare ident.
function let_1arg_ident
    priority 75
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg capture op_kind ident
    arg capture a0 ident
    write `{"event":"op","kind":${toJSON op_kind},"args":{"_0_var":${toJSON a0}},"capture_into":${toJSON name}}
`
end

function let_2args
    priority 100
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg capture op_kind ident
    arg capture a0 any
    arg capture a1 any
    write `{"event":"op","kind":${toJSON op_kind},"args":{"_0":${a0},"_1":${a1}},"capture_into":${toJSON name}}
`
end

# `let NAME = exec BIN token …` — capture a subprocess's stdout.
# `exec` is a LITERAL here (not the generic op_kind capture) so the bin
# routes to "bin" and the remaining tokens to argv slots "_0".."_N",
# exactly like the statement-form exec overloads above. High priority so
# these win over the generic let_Nargs forms (which would mis-route the
# bin into "_0"). Token rules match inline exec: bare idents OK, quote
# flags/paths.
# `let NAME = exec BIN tok …` — capture stdout. `exec` is a literal so the
# bin routes to "bin" and tokens to argv (same word rules as inline exec).
function let_exec_0args
    priority 235
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg literal "exec"
    arg capture bin word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin}},"capture_into":${toJSON name}}
`
end

function let_exec_1args
    priority 240
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0}},"capture_into":${toJSON name}}
`
end

function let_exec_2args
    priority 245
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1}},"capture_into":${toJSON name}}
`
end

function let_exec_3args
    priority 250
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2}},"capture_into":${toJSON name}}
`
end

function let_exec_4args
    priority 255
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    arg capture a3 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2},"_3":${asString a3}},"capture_into":${toJSON name}}
`
end

function let_exec_5args
    priority 260
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    arg capture a3 word
    arg capture a4 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2},"_3":${asString a3},"_4":${asString a4}},"capture_into":${toJSON name}}
`
end

# ────────────────────────────────────────────────────────────────────────────
# Assertion ops — thin sugar for tests. Each is 2-arg (or 1-arg for the
# existence checks) and fails the surrounding test on mismatch.

# ────────────────────────────────────────────────────────────────────────────
# Version assertions — infix comparison reads like math.
#
#   assert_version "${v}" >= "1.28.0"
#   assert_version "${v}" <  "2.0.0"
#   assert_version "${v}" == "1.29.3"
#
# Six grammar functions (one per operator) all emit the same op kind
# with the operator carried in args. Halts with err.kind = assert_failed
# if the comparison fails — composes with try/rescue.
# ────────────────────────────────────────────────────────────────────────────

# Ident form — `assert_version v >= "1.28.0"`. The lhs is a binding
# name resolved at runtime (args._lhs_var carries the name; handler
# does the lookup). Higher priority than the string form so a bare
# ident captures cleanly.
function assert_version_ge_ident
    priority 50
    arg literal "assert_version"
    arg capture lhs ident
    arg literal ">="
    arg capture rhs string
    write `{"event":"op","kind":"assert_version","args":{"op":"ge","_lhs_var":${toJSON lhs},"rhs":${rhs}}}
`
end

function assert_version_gt_ident
    priority 50
    arg literal "assert_version"
    arg capture lhs ident
    arg literal ">"
    arg capture rhs string
    write `{"event":"op","kind":"assert_version","args":{"op":"gt","_lhs_var":${toJSON lhs},"rhs":${rhs}}}
`
end

function assert_version_le_ident
    priority 50
    arg literal "assert_version"
    arg capture lhs ident
    arg literal "<="
    arg capture rhs string
    write `{"event":"op","kind":"assert_version","args":{"op":"le","_lhs_var":${toJSON lhs},"rhs":${rhs}}}
`
end

function assert_version_lt_ident
    priority 50
    arg literal "assert_version"
    arg capture lhs ident
    arg literal "<"
    arg capture rhs string
    write `{"event":"op","kind":"assert_version","args":{"op":"lt","_lhs_var":${toJSON lhs},"rhs":${rhs}}}
`
