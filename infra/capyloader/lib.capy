# ~ is the "same major" / compatibility check (PEP 440 ~= / Cargo caret).
function assert_version_compat_infix
    arg literal "assert_version"
    arg capture lhs word
    arg literal "~"
    arg capture rhs word
    write `{"event":"op","kind":"assert_version","args":{"op":"compat","lhs":${asString lhs},"rhs":${asString rhs}}}
`
end

