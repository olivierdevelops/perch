# Environment management:
#   export NAME "value"   — set a process-lifetime env var (alias set_env)
#   unset  NAME           — remove an env var (alias unset_env)
# For env that auto-restores at block exit, use `with_env "K=v" ... end`.
function export_env
    arg literal "export"
    arg capture name string
    arg capture value string
    write `{"event":"op","kind":"set_env","args":{"name":${name},"value":${value}}}
`
end
function set_env_op
    arg literal "set_env"
    arg capture name string
    arg capture value string
    write `{"event":"op","kind":"set_env","args":{"name":${name},"value":${value}}}
`
end
function unset_env_op
    arg literal "unset"
    arg capture name string
    write `{"event":"op","kind":"unset_env","args":{"name":${name}}}
`
end
function unset_env_op2
    arg literal "unset_env"
    arg capture name string
    write `{"event":"op","kind":"unset_env","args":{"name":${name}}}
`
end

