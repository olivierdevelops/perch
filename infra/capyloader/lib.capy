# perch DSL — the surface grammar users write.
#
# Capy parses each user-written .capy file with this library and emits a
# stream of NDJSON events. The Go loader consumes the stream and builds a
# domain.Program. No context state is used — every function just `write`s
# one (or a few) JSON-line event(s).
#
# Interpolation conventions inside `write \`...\``:
#   • ${v}            — capture's source text. For `string`/`int`/`bool`/
#                       `any` captures this is already valid JSON.
#   • ${toJSON name}  — for `ident` captures (bare identifiers need quoting
#                       to become valid JSON strings).

extension json

# `#` line comments — leading or trailing — are ignored by the parser.
# Capy ships no default comment marker (a target language might use `#`
# as data), so perch opts in here. (capy >= 5102dec.)
comments
    line "#"
end

# ────────────────────────────────────────────────────────────────────────────
# Top-level
# ────────────────────────────────────────────────────────────────────────────

function name
    arg literal "name"
    arg capture v string
    write `{"event":"name","value":${v}}
`
end

function about
    arg literal "about"
    arg capture v string
    write `{"event":"about","value":${v}}
`
end

function version
    arg literal "version"
    arg capture v string
    write `{"event":"version","value":${v}}
`
end

# `import "PATH"` — pull in another .perch file's commands flat into
# this program (callable by their bare names). Conflicts surface at
# --check.
function import_flat
    arg literal "import"
    arg capture path string
    write `{"event":"import","path":${path},"alias":""}
`
end

# `import "PATH" as NAMESPACE` — pull in another .perch file's commands
# under a NAMESPACE prefix (callable as NAMESPACE.command_name). Same
# file-level grammar; alias controls how commands are exposed.
function import_aliased
    priority 100
    arg literal "import"
    arg capture path string
    arg literal "as"
    arg capture alias ident
    write `{"event":"import","path":${path},"alias":${toJSON alias}}
`
end

# ────────────────────────────────────────────────────────────────────────────
# globals { NAME = LITERAL } block
# ────────────────────────────────────────────────────────────────────────────

function globals
    arg literal "globals"
    block_closer end
    write `{"event":"globals_begin"}
${body}{"event":"globals_end"}
`
end

# ────────────────────────────────────────────────────────────────────────────
# bundle ... end — declarative file-tree embedding for `perch --build`.
# Lifts the `--include CLI` flag into the source file. CLI --include
# remains additive on top of the declared set.
# ────────────────────────────────────────────────────────────────────────────

function bundle
    arg literal "bundle"
    block_closer end
    write `{"event":"bundle_begin"}
${body}{"event":"bundle_end"}
`
end

# One path inside a bundle block:
#
#   include "PATH"            — embed; address at runtime by path
#   include "PATH" as NAME    — embed AND register NAME as a bare-ident
#                               alias for the entry (used by ops like
#                               `wasm_run NAME`)
#
# Two grammar functions overloaded by arity. Higher-priority "with alias"
# tries first; the bare-string form is the fall-through.

function bundle_include_alias
    priority 50
    arg literal "include"
    arg capture path any
    arg literal "as"
    arg capture alias ident
    write `{"event":"bundle_include","value":${path},"alias":${toJSON alias}}
`
end

function bundle_include
    arg literal "include"
    arg capture path any
    write `{"event":"bundle_include","value":${path}}
`
end

# ────────────────────────────────────────────────────────────────────────────
# requires ... end — file-declared manifest (the file states what it needs).
#
#   requires
#       bin "kubectl" >= "1.28.0"
#       bin "docker"  optional
#       env "KUBECONFIG"
#       env "DEBUG"   optional
#       host "api.github.com"
#       os   "linux"
#       arch "amd64"
#   end
#
# When this block is present, runtime enforcement is STRICT: undeclared
# shell bins, env reads, and HTTP hosts error (bin_not_declared etc.).
# Files without a `requires` block keep current behavior.
# ────────────────────────────────────────────────────────────────────────────

function requires
    arg literal "requires"
    block_closer end
    write `{"event":"requires_begin"}
${body}{"event":"requires_end"}
`
end

# Sub-lines that customize the most-recent `bin ...` declaration. Indentation
# under a `bin` line is stylistic; the loader applies these field events to
# the last BinReq in the requires block. `hash` / `hash_file` PIN the binary's
# bytes — a read-only check, no execution. (There is no version probe: that
# would require running the binary before the sandbox exists, and a trojaned
# binary lies about its version. Pin the artifact, don't ask it to self-report.)
function requires_bin_hash
    arg literal "hash"
    arg capture v any
    write `{"event":"requires_bin_field","kind":"hash","value":${v}}
`
end
function requires_bin_hash_file
    arg literal "hash_file"
    arg capture v any
    write `{"event":"requires_bin_field","kind":"hash_file","value":${v}}
`
end

# bin "NAME" optional
function requires_bin_optional
    priority 55
    arg literal "bin"
    arg capture name any
    arg literal "optional"
    write `{"event":"requires_bin","name":${name},"optional":true}
`
end

# bin "NAME"
function requires_bin
    priority 40
    arg literal "bin"
    arg capture name any
    write `{"event":"requires_bin","name":${name}}
`
end

function requires_env_optional
    priority 55
    arg literal "env"
    arg capture name any
    arg literal "optional"
    write `{"event":"requires_env","name":${name},"optional":true}
`
end

function requires_env
    priority 40
    arg literal "env"
    arg capture name any
    write `{"event":"requires_env","name":${name}}
`
end

function requires_host_optional
    priority 55
    arg literal "host"
    arg capture name any
    arg literal "optional"
    write `{"event":"requires_host","name":${name},"optional":true}
`
end

function requires_host
    priority 40
    arg literal "host"
    arg capture name any
    write `{"event":"requires_host","name":${name}}
`
end

# read "PATH" / write "PATH" — filesystem scopes the program may touch.
# One path per line, repeatable. The filesystem is an external resource,
# so it's declared like bins/hosts/env. A write root implies read.
function requires_read
    arg literal "read"
    arg capture path any
    write `{"event":"requires_read","value":${path}}
`
end

function requires_write
    arg literal "write"
    arg capture path any
    write `{"event":"requires_write","value":${path}}
`
end

# Inside a `requires` block, `os "linux"` / `arch "amd64"` declare the host
# OS/arch allowlist. These share the bare `os` / `arch` keyword with the
# `os "..." ... end` / `arch "..." ... end` execution-context conditional
# blocks (os_block / arch_block below) — disambiguated by INDENT lookahead
# (capy >= 5102dec): a requires entry is NOT followed by an indented body;
# the conditional block IS. Deterministic, so both forms coexist on the same
# keyword. (Earlier this needed the `run_on` / `run_arch` rename — no longer.)
function requires_os
    arg literal "os"
    arg capture name any
    when_not_followed_by indent
    write `{"event":"requires_os","name":${name}}
`
end

function requires_arch
    arg literal "arch"
    arg capture name any
    when_not_followed_by indent
    write `{"event":"requires_arch","name":${name}}
`
end

# One assignment line: NAME = LITERAL. The Go side reads the JSON type.
function global_assign
    arg capture k ident
    arg literal "="
    arg capture v any
    write `{"event":"global","name":${toJSON k},"value":${v}}
`
end

# ────────────────────────────────────────────────────────────────────────────
# command NAME ... end / catch NAME ... end
# ────────────────────────────────────────────────────────────────────────────

function command
    arg literal "command"
    arg capture name ident
    block_closer end
    write `{"event":"command_begin","name":${toJSON name}}
${body}{"event":"command_end"}
`
end

function catch
    arg literal "catch"
    arg capture name ident
    block_closer end
    write `{"event":"catch_begin","name":${toJSON name}}
${body}{"event":"catch_end"}
`
end

# `template NAME ... end` — a parse-time stamp with the same arg-block
# syntax as `command`. Templates expand inline at each `call NAME ...`
# site, with positional args substituted as ${NAME} bindings in the
# expanded ops. Templates don't appear in --help, can't be invoked from
# the CLI, and don't show up in MCP.
function template
    arg literal "template"
    arg capture name ident
    block_closer end
    write `{"event":"template_begin","name":${toJSON name}}
${body}{"event":"template_end"}
`
end

# ────────────────────────────────────────────────────────────────────────────
# Inside a command body: config statements (before `do`)
# ────────────────────────────────────────────────────────────────────────────

function description
    arg literal "description"
    arg capture v string
    write `{"event":"config","kind":"description","value":${v}}
`
end

# ── Argument declarations ─────────────────────────────────────────────────
#
# Each arg is its own block:
#
#   arg NAME
#       type string             # required: string / int / float / bool
#       default "world"         # optional: literal value
#       description "Who…"      # optional: shown in --help
#       optional                # optional: arg may be omitted with no default
#       index 0                 # optional: bind to positional index
#   end
#
# Field statements only emit `arg_field` events; the loader applies them
# to the currently-open arg.

function arg
    arg literal "arg"
    arg capture name ident
    block_closer end
    write `{"event":"arg_begin","name":${toJSON name}}
${body}{"event":"arg_end"}
`
end

function type
    arg literal "type"
    arg capture t ident
    write `{"event":"arg_field","kind":"type","value":${toJSON t}}
`
end

function default
    arg literal "default"
    arg capture v any
    write `{"event":"arg_field","kind":"default","value":${v}}
`
end

function optional
    arg literal "optional"
    write `{"event":"arg_field","kind":"optional"}
`
end

# `rest` — declared on the LAST positional arg, it collects every
# remaining argv into a newline-joined string. Also binds NAME_count
# (int) for the number of values gathered. Equivalent to Go's
# `args ...string`.
function rest
    arg literal "rest"
    write `{"event":"arg_field","kind":"rest"}
`
end

function index
    arg literal "index"
    arg capture i int
    write `{"event":"arg_field","kind":"index","value":${i}}
`
end

function private
    arg literal "private"
    write `{"event":"config","kind":"private"}
`
end

# ── Test modifiers ───────────────────────────────────────────────────────
# `test` marks a command as a test, discovered by `perch test`. Sandboxed
# by default (temp cwd, --no-network, --no-shell, --no-subprocess on,
# write-root pinned to the temp cwd). Opt-outs follow.

function test_mod
    arg literal "test"
    write `{"event":"config","kind":"test"}
`
end

function test_allow_network
    arg literal "test_allow_network"
    write `{"event":"config","kind":"test_allow_network"}
`
end

function test_allow_shell
    arg literal "test_allow_shell"
    write `{"event":"config","kind":"test_allow_shell"}
`
end

function test_allow_write
    arg literal "test_allow_write"
    write `{"event":"config","kind":"test_allow_write"}
`
end

function test_allow_subprocess
    arg literal "test_allow_subprocess"
    write `{"event":"config","kind":"test_allow_subprocess"}
`
end

function test_keep_cwd
    arg literal "test_keep_cwd"
    write `{"event":"config","kind":"test_keep_cwd"}
`
end

function test_timeout
    arg literal "test_timeout"
    arg capture secs int
    write `{"event":"config","kind":"test_timeout","value":${secs}}
`
end

function detached
    arg literal "detached"
    write `{"event":"config","kind":"detached"}
`
end

function proxy_args
    arg literal "proxy_args"
    write `{"event":"config","kind":"proxy_args"}
`
end

function require_os
    arg literal "require_os"
    arg capture v string
    write `{"event":"config","kind":"require_os","value":${v}}
`
end

function require_arch
    arg literal "require_arch"
    arg capture v string
    write `{"event":"config","kind":"require_arch","value":${v}}
`
end

function dir
    arg literal "dir"
    arg capture v string
    write `{"event":"config","kind":"dir","value":${v}}
`
end

function on_signal
    arg literal "on_signal"
    arg capture handler ident
    write `{"event":"config","kind":"on_signal","value":${toJSON handler}}
`
end

function env
    arg literal "env"
    arg capture k ident
    arg capture v string
    write `{"event":"config","kind":"env","name":${toJSON k},"value":${v}}
`
end

# ────────────────────────────────────────────────────────────────────────────
# `do ... end` body block
# ────────────────────────────────────────────────────────────────────────────

function do
    arg literal "do"
    block_closer end
    write `{"event":"do_begin"}
${body}{"event":"do_end"}
`
end

# ────────────────────────────────────────────────────────────────────────────
# Ops (used inside `do`)
# ────────────────────────────────────────────────────────────────────────────

function print
    arg literal "print"
    arg capture msg string
    write `{"event":"op","kind":"print","args":{"msg":${msg}}}
`
end
# Bare ident form — `print msg` (no quotes, no ${...}). Emits `_msg_var`
# which the universal resolver turns into `msg = b.Lookup(...)`.
function print_ident
    priority 60
    arg literal "print"
    arg capture name ident
    write `{"event":"op","kind":"print","args":{"_msg_var":${toJSON name}}}
`
end

function println
    arg literal "println"
    arg capture msg string
    write `{"event":"op","kind":"println","args":{"msg":${msg}}}
`
end
function println_ident
    priority 60
    arg literal "println"
    arg capture name ident
    write `{"event":"op","kind":"println","args":{"_msg_var":${toJSON name}}}
`
end

function eprintln
    arg literal "eprintln"
    arg capture msg string
    write `{"event":"op","kind":"eprintln","args":{"msg":${msg}}}
`
end
function eprintln_ident
    priority 60
    arg literal "eprintln"
    arg capture name ident
    write `{"event":"op","kind":"eprintln","args":{"_msg_var":${toJSON name}}}
`
end

function shell
    arg literal "shell"
    arg capture cmd string
    write `{"event":"op","kind":"shell","args":{"cmd":${cmd}}}
`
end
function shell_ident
    priority 60
    arg literal "shell"
    arg capture name ident
    write `{"event":"op","kind":"shell","args":{"_cmd_var":${toJSON name}}}
`
end

function shell_detached
    arg literal "shell_detached"
    arg capture cmd string
    write `{"event":"op","kind":"shell_detached","args":{"cmd":${cmd}}}
`
end

# ── exec — run a DECLARED binary with structured argv, no shell ────────────
#
# `exec BIN token token …` spawns BIN directly (os/exec, never `sh -c`).
# Each token is exactly one argv slot — there is no word-splitting, no
# globbing, no metachar surface. BIN must be a declared `bin` in `requires`
# (when a requires block is present) or the op fails `bin_not_declared`.
#
# Token rules (capy tokenizer): bare identifiers (`status`, `build`) work
# unquoted; flags / paths / anything with `-` `/` `.` `=` must be quoted
# (`exec docker "run" "-d" "--name" "web"`); `${x}` interpolates one slot
# when written as `"${x}"`. The captured stdout is the op's value
# (`let out = exec git "rev-parse" "HEAD"`) and is also streamed.
#
# This is the core of docs/sandboxed-by-design.md §3.1–3.2: the only way to
# run a subprocess without a shell. See also `with_exec` (§3.4).


# `pipe ... end` — wire stdout→stdin between exec stages with in-process
# pipes (no shell). Each body line is an `exec BIN …` stage; perch connects
# stage N's stdout to stage N+1's stdin. The block's value is the LAST
# stage's stdout (capture with `let out = ...`). docs/sandboxed-by-design §3.5.
#
#   let names =
#       pipe
#           exec kubectl "get" "pods" "-o" "json"
#           exec jq "-r" ".items[].metadata.name"
#           exec sort
#       end
function pipe
    arg literal "pipe"
    block_closer end
    write `{"event":"op","kind":"_enter","name":"pipe","args":{}}
${body}{"event":"op","kind":"_leave"}
`
end

# `let NAME = pipe ... end` — capture the pipeline's final stdout. The
# capture_into rides on the _enter event; the loader binds the block op's
# return value (opPipe returns the last stage's stdout).
function let_pipe
    priority 300
    arg literal "let"
    arg capture name ident
    arg literal "="
    arg literal "pipe"
    block_closer end
    write `{"event":"op","kind":"_enter","name":"pipe","args":{},"capture_into":${toJSON name}}
${body}{"event":"op","kind":"_leave"}
`
end
# ── exec — run a DECLARED binary with structured argv, no shell ────────────
# `exec BIN tok tok …` spawns BIN directly (os/exec, never `sh -c`). Each
# token (`word`) is one argv slot: bare flags/paths/globs work unquoted
# (`exec git log --oneline -10`), and a quoted token keeps embedded spaces
# as one slot (`exec git commit -m "fix the bug"`). `${x}` interpolates a
# slot. Captured stdout is the op's value and is also streamed. Core of
# docs/sandboxed-by-design.md §3.1–3.2. (capy >= 5102dec: word + asString.)
function exec
    arg literal "exec"
    arg capture bin word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin}}}
`
end

function exec_1args
    priority 50
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0}}}
`
end

function exec_2args
    priority 100
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1}}}
`
end

function exec_3args
    priority 150
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2}}}
`
end

function exec_4args
    priority 200
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    arg capture a3 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2},"_3":${asString a3}}}
`
end

function exec_5args
    priority 250
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    arg capture a3 word
    arg capture a4 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2},"_3":${asString a3},"_4":${asString a4}}}
`
end

function exec_6args
    priority 300
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    arg capture a3 word
    arg capture a4 word
    arg capture a5 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2},"_3":${asString a3},"_4":${asString a4},"_5":${asString a5}}}
`
end

function exec_7args
    priority 350
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    arg capture a3 word
    arg capture a4 word
    arg capture a5 word
    arg capture a6 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2},"_3":${asString a3},"_4":${asString a4},"_5":${asString a5},"_6":${asString a6}}}
`
end

function exec_8args
    priority 400
    arg literal "exec"
    arg capture bin word
    arg capture a0 word
    arg capture a1 word
    arg capture a2 word
    arg capture a3 word
    arg capture a4 word
    arg capture a5 word
    arg capture a6 word
    arg capture a7 word
    write `{"event":"op","kind":"exec","args":{"bin":${asString bin},"_0":${asString a0},"_1":${asString a1},"_2":${asString a2},"_3":${asString a3},"_4":${asString a4},"_5":${asString a5},"_6":${asString a6},"_7":${asString a7}}}
`
end


function fail
    arg literal "fail"
    arg capture msg string
    write `{"event":"op","kind":"fail","args":{"msg":${msg}}}
`
end

function exit
    arg literal "exit"
    arg capture code int
    write `{"event":"op","kind":"exit","args":{"code":${code}}}
`
end

function sleep
    arg literal "sleep"
    arg capture seconds any
    write `{"event":"op","kind":"sleep","args":{"seconds":${seconds}}}
`
end

function list_commands
    arg literal "list_commands"
    write `{"event":"op","kind":"list_commands","args":{}}
`
end

function run
    arg literal "run"
    arg capture target ident
    write `{"event":"op","kind":"run","args":{"target":${toJSON target}}}
`
end

# Overloads for `run NAME [args...]`. Trailing tokens are captured as
# raw strings and re-parsed by the run handler using the SAME CLI flag
# parser that handles `perch NAME -arg=value` from a shell. Up to 8
# args supported via priority-ordered overloads (matches the call_*
# template-call pattern).
#
#   run build_for -target=darwin            # one arg (-name=value form)
#   run deploy   -region=us-east-1 -bake=15  # multiple
#   run promote  -env staging                # two-token form
#                                             # (--name and -name both work)
#
# Each captured token must be a non-empty `any` literal (string OR an
# identifier-shaped token). The handler joins them into a []string and
# feeds parseArgs.

function run_1arg
    priority 50
    arg literal "run"
    arg capture target ident
    arg capture a0 any
    write `{"event":"op","kind":"run","args":{"target":${toJSON target},"_0":${a0}}}
`
end

function run_2args
    priority 100
    arg literal "run"
    arg capture target ident
    arg capture a0 any
    arg capture a1 any
    write `{"event":"op","kind":"run","args":{"target":${toJSON target},"_0":${a0},"_1":${a1}}}
`
end

function run_3args
    priority 150
    arg literal "run"
    arg capture target ident
    arg capture a0 any
    arg capture a1 any
    arg capture a2 any
    write `{"event":"op","kind":"run","args":{"target":${toJSON target},"_0":${a0},"_1":${a1},"_2":${a2}}}
`
end

function run_4args
    priority 200
    arg literal "run"
    arg capture target ident
    arg capture a0 any
    arg capture a1 any
    arg capture a2 any
    arg capture a3 any
    write `{"event":"op","kind":"run","args":{"target":${toJSON target},"_0":${a0},"_1":${a1},"_2":${a2},"_3":${a3}}}
`
end

# `run NAMESPACE.COMMAND` — call a command imported under a namespace.
# Higher priority than the bare-ident form so the dot-separated path
# is matched first when present.
function run_ns
    priority 100
    arg literal "run"
    arg capture ns ident
    arg literal "."
    arg capture cmd ident
    write `{"event":"op","kind":"run","args":{"target":"${ns}.${cmd}"}}
`
end

