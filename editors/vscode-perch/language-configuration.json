{
  "comments": { "lineComment": "#" },
  "brackets": [["{", "}"], ["[", "]"], ["(", ")"]],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [["{", "}"], ["[", "]"], ["(", ")"], ["\"", "\""], ["'", "'"]],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(command|globals|do|if_(os|arch|exists|eq|neq|gt|lt|empty|not_empty)|catch|for_each)\\b.*$",
    "decreaseIndentPattern": "^\\s*end\\s*$"
  }
}
