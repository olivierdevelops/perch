{
  "type": "object",
  "required": ["id", "email", "role"],
  "additionalProperties": false,
  "properties": {
    "id":    { "type": "integer", "minimum": 1 },
    "email": { "type": "string",  "pattern": "^[^@]+@[^@]+\\.[^@]+$" },
    "role":  { "type": "string",  "enum": ["admin", "user", "guest"] },
    "age":   { "type": "integer", "minimum": 0, "maximum": 150 }
  }
}
